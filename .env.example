# TenderMind Environment Variables
# Bu faylni .env ga ko'chiring va qiymatlarni to'ldiring:
#   cp .env.example .env

# ─── Claude AI API Key ──────────────────────────────────────────────
# Olish uchun: https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ─── JWT Secret ─────────────────────────────────────────────────────
# Production uchun kamida 32 belgilik tasodifiy string ishlating
# Yaratish: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your-super-secret-jwt-key-min-32-chars

# ─── Server sozlamalari ─────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ─── AI model sozlamalari (ixtiyoriy) ──────────────────────────────
# Default: claude-sonnet-4-6
# Arzonroq: claude-haiku-4-5-20251001
ANTHROPIC_CHAT_MODEL=claude-sonnet-4-6

# ─── CORS sozlamalari ────────────────────────────────────────────────
# Production uchun domenlarni vergul bilan ajrating
# Development uchun localhost ruxsat berilgan (qo'shimcha sozlash shart emas)
ALLOWED_ORIGINS=http://localhost:3000,https://yourdomain.com

# ─── Log darajasi ───────────────────────────────────────────────────
# Qiymatlar: debug, info, warn, error
LOG_LEVEL=info
