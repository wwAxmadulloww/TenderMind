# TenderMind Environment Variables
# Bu faylni .env ga ko'chiring va qiymatlarni to'ldiring:
#   cp .env.example .env

# ─── Groq API Key (ASOSIY — BEPUL) ──────────────────────────────────
# Olish uchun: https://console.groq.com  (bepul, juda tez)
# LLaMA-3.3-70b modeli ishlatiladi
GROQ_API_KEY=gsk_your-groq-api-key-here

# ─── OpenAI API Key (Fallback) ───────────────────────────────────────
# Olish uchun: https://platform.openai.com/api-keys
# Groq ishlamasa GPT-4o-mini ishlatiladi
OPENAI_API_KEY=sk-proj-your-openai-key-here

# ─── Google Gemini API Key (Oxirgi fallback) ─────────────────────────
# Olish uchun: https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# ─── MongoDB URI ─────────────────────────────────────────────────────
# MongoDB Atlas: https://cloud.mongodb.com
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/?appName=TenderMind

# ─── JWT Secret ─────────────────────────────────────────────────────
# Production uchun kamida 32 belgilik tasodifiy string ishlating!
# Yaratish:  node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=CHANGE-THIS-TO-A-LONG-RANDOM-STRING-min-32-chars

# ─── Server sozlamalari ─────────────────────────────────────────────
PORT=4020
NODE_ENV=development

# ─── Frontend URL (CORS uchun, Render deploy) ───────────────────────
# Render domeningizni kiriting:
FRONTEND_URL=https://your-app.onrender.com

# ─── Log darajasi ───────────────────────────────────────────────────
# Qiymatlar: debug, info, warn, error
LOG_LEVEL=info
